{
  "name": "matchx",
  "private": true,
  "packageManager": "npm@10.9.4",
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "npm run test:codestyles",
    "check-types": "npm run test:type",
    "test:unit": "turbo run test:unit",
    "test:type": "turbo run test:type",
    "test:codestyles": "turbo run test:codestyles",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@semantic-release/github": "^12.0.6",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.3",
    "turbo": "^2.9.18",
    "typescript": "^5.8.2"
  }
}
